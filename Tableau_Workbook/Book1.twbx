      <aliases enabled='yes' />
      <column datatype='integer' name='[#]' role='measure' type='quantitative' />
      <column aggregation='CountD' datatype='integer' name='[Active Cases]' role='measure' type='quantitative' />
      <column caption='Include Cases' datatype='integer' default-format='n#,##0,,.00M;-#,##0,,.00M' name='[Calculation_0261420258533376]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{INCLUDE [Country, Other]:SUM([Total Cases])}' />
      </column>
      <column aggregation='Attribute' caption='Exclude Cases' datatype='integer' default-format='n#,##0,,.00M;-#,##0,,.00M' name='[Calculation_0261420258770945]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{EXCLUDE [Country, Other]:SUM([Total Cases])}' />
      </column>
      <column caption='Prevous Country Cases' datatype='integer' name='[Calculation_0261420261416962]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOOKUP(sum([Total Cases]),-1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Window Sum' datatype='integer' name='[Calculation_0261420263108611]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_SUM(sum([Total Cases]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Winodow Avg' datatype='real' default-format='n#,##0,,.0M;-#,##0,,.0M' name='[Calculation_0261420263833604]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(sum([Total Cases]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Index' datatype='integer' name='[Calculation_0261420264308741]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INDEX()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Calculation1' datatype='datetime' name='[Calculation_0261420267028487]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEADD(&apos;month&apos;,2,#2020-02-15#)' />
      </column>
      <column caption='Selected Metrc' datatype='integer' name='[Calculation_0452734906560512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Total Cases&quot; THEN [Total Cases]&#13;&#10;WHEN &quot;Total Deaths&quot; THEN[Total Deaths]&#13;&#10;WHEN &quot;Total Recovered&quot; THEN[Total Recovered]&#13;&#10;END' />
      </column>
      <column caption='Active Case Rate' datatype='real' default-format='p0.00%' name='[Calculation_0452734914965505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Active Cases]/[Total Cases]*100' />
      </column>
      <column caption='Global' datatype='integer' name='[Calculation_0452734930411522]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :SUM([Total Cases]) }' />
      </column>
      <column caption='Country Contribution' datatype='real' default-format='p0.00%' name='[Calculation_0452734931390467]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Total Cases]/[Calculation_0452734930411522]' />
      </column>
      <column caption='Rank by Cases' datatype='integer' name='[Calculation_0452734937427975]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Total Cases]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top N Filter' datatype='boolean' name='[Calculation_0452734937575432]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Total Cases])) &lt;= [Parameters].[Top 10 Parameter]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='New' datatype='real' hidden='true' name='[Calculation_0908207285485568]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='' />
      </column>
      <column caption='Death Rate' datatype='real' datatype-customized='true' default-format='p0.00%' name='[Calculation_0908207412158467]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Total Deaths]/[Total Cases])' />
      </column>
      <column caption='Recovery Rate' datatype='real' default-format='p0.00%' name='[Calculation_0908207417163780]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total Recovered])/Sum([Total Cases])' />
      </column>
      <column datatype='string' name='[Country, Other]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column datatype='integer' hidden='true' name='[New Deaths]' role='measure' type='quantitative' />
